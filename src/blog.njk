---
layout: base.njk
title: Blog
pagination:
  data: collections.post
  size: 9
  alias: posts
  reverse: true
---

<div class="mx-auto max-w-7xl px-6 pt-36 sm:pt-60 lg:px-8 lg:pt-32">
    <div class="mx-auto">

        {% if posts.length > 0 %}

            {# --- 2. Featured Card (The first item: posts[0]) --- #}
            {% set post = posts[0] %}
            <article class="relative isolate flex flex-col justify-end overflow-hidden rounded-2xl bg-gray-900 px-8 pb-8 pt-80 sm:pt-48 lg:pt-80 mb-8">
                {% image "src" + (post.data.image | default('/assets/images/hero-2.jpg')), post.data.imageAlt | default('post image'), "absolute inset-0 -z-10 h-full w-full object-cover" %}
                <div class="absolute inset-0 -z-10 bg-gradient-to-t from-gray-900 via-gray-900/40"></div>
                <div class="absolute inset-0 -z-10 rounded-2xl ring-1 ring-inset ring-gray-900/10"></div>

                <div class="flex flex-wrap items-center gap-y-1 overflow-hidden text-sm leading-6 text-gray-300">
                    <time datetime="{{ post.date }}" class="mr-8">{{ post.date | postDate }}</time>
                    <div class="-ml-4 flex items-center gap-x-4">
                        <svg viewBox="0 0 2 2" class="-ml-0.5 h-0.5 w-0.5 flex-none fill-white/50">
                            <circle r="1" cx="1" cy="1" />
                        </svg>
                        <div class="flex gap-x-2.5">
                            Kadir Gülec
                        </div>
                    </div>
                </div>
                <h3 class="mt-3 text-3xl font-bold leading-6 text-white">
                    <a href="{{ post.url }}">
                        <span class="absolute inset-0"></span>
                        {{ post.data.title }}
                    </a>
                </h3>
                <p class="mt-4 text-gray-300">
                    {{ post.templateContent | striptags | truncate(200) | safe }}
                </p>
            </article>

            {# --- 3. Grid Layout (Remaining items) --- #}
            {% if posts.length > 1 %}
                <div class="lg:grid lg:grid-cols-6 pt-4 space-y-4 lg:space-y-0 lg:gap-4 max-w-2xl lg:max-w-none mx-auto">

                    {% for p in posts %}
                        {% if not loop.first %}
                            {# Logic: First 2 items get col-span-3, others get col-span-2 #}
                            {% set spanClass = "col-span-2" %}
                            {% if loop.index <= 3 %}
                                 {% set spanClass = "col-span-3" %}
                            {% endif %}

                            <article class="relative flex flex-col justify-end overflow-hidden rounded-2xl px-8 pb-8 pt-40 {{ spanClass }}">
                                {% set imagePath = p.data.image | default('/assets/images/hero-2.jpg') %}
                                {% image "src" + imagePath, p.data.imageAlt | default(p.data.title), "absolute inset-0 -z-10 h-full w-full object-cover transition duration-300 hover:scale-105" %}
                                <div class="absolute inset-0 -z-10 bg-gradient-to-t from-gray-900 via-gray-900/40"></div>
                                   <div class="absolute inset-0 -z-10 rounded-2xl ring-1 ring-inset ring-gray-900/10"></div>

                                <div class="flex flex-wrap items-center gap-y-1 overflow-hidden text-sm leading-6 text-gray-300">
                                    <time datetime="{{ p.date }}" class="mr-8">{{ p.date | postDate }}</time>
                                </div>
                                <h3 class="mt-3 text-lg font-semibold leading-6 text-white">
                                    <a href="{{ p.url }}">
                                        <span class="absolute inset-0"></span>
                                        {{ p.data.title }}
                                    </a>
                                </h3>
                            </article>
                        {% endif %}
                    {% endfor %}

                </div>
            {% endif %}

            {# --- 4. Pagination Links --- #}
            {% if pagination.href.next or pagination.href.previous %}
                <div class="py-10 flex justify-center gap-4">
                    {% if pagination.href.previous %}
                        <a href="{{ pagination.href.previous }}" class="button-soft">Previous</a>
                    {% endif %}
                    {% if pagination.href.next %}
                        <a href="{{ pagination.href.next }}" class="button-soft">Next</a>
                    {% endif %}
                </div>
            {% endif %}

        {% else %}
            <p class="text-center text-white text-xl">No articles published yet. Check back soon!</p>
        {% endif %}

    </div>
</div>
