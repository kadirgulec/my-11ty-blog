<!DOCTYPE html>
<html lang="{{ lang or 'en' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {% set pageUrl = site.url + page.url %}
    {% set pageDescription = description or 'Kadir Gülec - Software Developer Portfolio' %}
    {% if image %}
        {% set pageImage = site.url + image %}
    {% elif layout == 'post.njk' %}
        {% set pageImage = site.url + '/assets/og/' + page.url.split('/')[2] + '.png' %}
    {% else %}
        {% set pageImage = site.url + '/assets/images/hero-1.jpg' %}
    {% endif %}

    <title>{{ title }}{% if page.url != '/' %} | {{ site.author }}{% endif %}</title>
    <meta name="description" content="{{ pageDescription }}">
    <meta name="author" content="{{ site.author }}">
    <link rel="canonical" href="{{ pageUrl }}">

    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:type" content="{{ 'article' if layout == 'post.njk' else 'website' }}">
    <meta property="og:url" content="{{ pageUrl }}">
    <meta property="og:image" content="{{ pageImage }}">
    {% if imageAlt %}<meta property="og:image:alt" content="{{ imageAlt }}">{% endif %}
    <meta property="og:site_name" content="{{ site.name }}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    <meta name="twitter:image" content="{{ pageImage }}">

    {% if robots %}
    <meta name="robots" content="{{ robots }}">
    {% endif %}

    {% if page.url == '/' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "{{ site.author }}",
      "url": "{{ site.url }}",
      "jobTitle": "Software Developer",
      "worksFor": {
        "@type": "Organization",
        "name": "aks-Service GmbH"
      },
      "sameAs": ["https://github.com/kadirgulec"]
    }
    </script>
    {% elif layout == 'post.njk' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": {{ title | dump | safe }},
      "description": {{ pageDescription | dump | safe }},
      "url": "{{ pageUrl }}",
      "image": "{{ pageImage }}",
      "datePublished": "{{ page.date | isoDate }}",
      "inLanguage": "en",
      "author": {
        "@type": "Person",
        "name": "{{ site.author }}",
        "url": "{{ site.url }}"
      },
      "mainEntityOfPage": "{{ pageUrl }}"
    }
    </script>
    {% endif %}

    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
    <link rel="manifest" href="/assets/site.webmanifest">
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#111827" media="(prefers-color-scheme: dark)">
    <link rel="alternate" type="application/rss+xml" title="{{ site.name }} — Blog" href="{{ site.url }}/feed.xml">
     <script>
        // Check local storage or system preference
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark')
        }
    </script>

    <!-- Link to the Splide CSS file (before style.css so site overrides win) -->
    <link rel="stylesheet" href="/assets/vendor/splide.min.css">
    <!-- Tailwind CSS Output -->
    <link rel="stylesheet" href="/style.css">
    <!-- Prism theme for build-time syntax highlighting -->
    <link rel="stylesheet" href="/assets/vendor/prism-tomorrow.min.css">
    <!-- Alpine.js -->
    <script defer src="/assets/vendor/alpine.min.js"></script>
</head>
<body class="bg-white dark:bg-gray-900 min-h-screen custom-scrollbar">
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 button-soft">Skip to content</a>
  <!-- Header -->
    {% include "header.njk" %}
  <main id="main" class="isolate" data-pagefind-body>
    {{ content | safe }}
  </main>

  <!-- Footer -->
  {% include "footer.njk" %}

  {% include "partials/search.njk" %}

<!-- Splide JS (Local) -->
<script src="/assets/vendor/splide.min.js"></script>

{% if site.goatcounter %}
<!-- GoatCounter: privacy-friendly analytics, no cookies -->
<script data-goatcounter="https://{{ site.goatcounter }}.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
{% endif %}
</body>
</html>