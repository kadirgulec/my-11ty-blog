<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {% set pageUrl = site.url + page.url %}
    {% set pageDescription = description or 'Kadir Gülec - Software Developer Portfolio' %}
    {% set pageImage = site.url + (image or '/assets/images/hero-1.jpg') %}

    <title>{{ title }}{% if page.url != '/' %} | {{ site.author }}{% endif %}</title>
    <meta name="description" content="{{ pageDescription }}">
    <meta name="author" content="{{ site.author }}">
    <link rel="canonical" href="{{ pageUrl }}">

    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:type" content="{{ 'article' if layout == 'post.njk' else 'website' }}">
    <meta property="og:url" content="{{ pageUrl }}">
    <meta property="og:image" content="{{ pageImage }}">
    {% if imageAlt %}<meta property="og:image:alt" content="{{ imageAlt }}">{% endif %}
    <meta property="og:site_name" content="{{ site.name }}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    <meta name="twitter:image" content="{{ pageImage }}">

    {% if robots %}
    <meta name="robots" content="{{ robots }}">
    {% endif %}

    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
    <link rel="alternate" type="application/rss+xml" title="{{ site.name }} — Blog" href="{{ site.url }}/feed.xml">
     <script>
        // Check local storage or system preference
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark')
        }
    </script>

    <!-- Tailwind CSS Output -->
    <link rel="stylesheet" href="/style.css">
    <!-- Link to the Splide CSS file -->
    <link rel="stylesheet" href="/assets/vendor/splide.min.css">
    <!-- Alpine.js -->
    <script defer src="/assets/vendor/alpine.min.js"></script>
</head>
<body class="bg-white dark:bg-gray-900 min-h-screen custom-scrollbar">
  <!-- Header -->
    {% include "header.njk" %}
  <main class="isolate" data-pagefind-body>
    {{ content | safe }}
  </main>

  <!-- Footer -->
  {% include "footer.njk" %}

  {% include "partials/search.njk" %}

<!-- Splide JS (Local) -->
<script src="/assets/vendor/splide.min.js"></script>
</body>
</html>