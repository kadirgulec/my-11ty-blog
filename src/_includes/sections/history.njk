{% macro entryContent(item) %}
  <p class="text-xs font-semibold uppercase tracking-wide {% if item.kind == 'education' %}text-green-600 dark:text-green-400{% else %}text-indigo-600 dark:text-indigo-400{% endif %}">{{ item.date }}</p>
  <h3 class="mt-1 text-base/7 font-semibold tracking-tight text-gray-900 dark:text-white">{{ item.role }}</h3>
  <p class="text-sm/6 text-gray-600 dark:text-gray-400">{{ item.place }}</p>
  {% if item.description %}
    <p class="mt-2 text-sm/6 text-gray-600 dark:text-gray-300">{{ item.description }}</p>
  {% endif %}
{% endmacro %}

{% macro marker(item, size = 'size-14', logoSize = 'max-w-10 max-h-10') %}
  {% if item.logo %}
    {% set markerBg = item.logoBg | default('bg-white') %}
  {% else %}
    {% set markerBg = 'bg-white dark:bg-gray-800' %}
  {% endif %}
  <div class="relative z-10 flex {{ size }} shrink-0 items-center justify-center overflow-hidden rounded-full {{ markerBg }} ring-1 {% if item.kind == 'education' %}ring-green-200 dark:ring-green-500/40{% else %}ring-indigo-200 dark:ring-indigo-500/40{% endif %}">
    {% if item.logo %}
      <img src="{{ item.logo }}" alt="{{ item.place }} logo" class="{{ logoSize }} object-contain" loading="lazy" width="40" height="40">
    {% elseif item.kind == 'education' %}
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-7 text-green-600 dark:text-green-400" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.57 50.57 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
      </svg>
    {% else %}
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-7 text-indigo-600 dark:text-indigo-400" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 2.622V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v2.375m15 0c0 .414-.168.75-.437.988M9 4.5v1.5h6V4.5M4.5 8.706c0 1.081.768 2.015 1.837 2.175a48.111 48.111 0 0 1 3.413.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z" />
      </svg>
    {% endif %}
  </div>
{% endmacro %}

<div id="history" class="mx-auto mt-32 max-w-7xl px-6 sm:mt-48 lg:px-8">
  <div class="mx-auto max-w-2xl lg:mx-0">
    <h2 class="text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl dark:text-white">Career History</h2>
    <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-400">
      My professional path and educational background that led me to where I am today.
    </p>
  </div>

  <ol role="list" class="relative mx-auto mt-20 max-w-3xl lg:mx-0">
    <div class="absolute bottom-2 left-7 top-2 w-px bg-gray-200 dark:bg-gray-800" aria-hidden="true"></div>

    {% for item in history %}
      {% if not item.parallel %}

        {% if item.gapNote %}
          <li class="relative flex gap-x-6 pb-14">
            <div class="relative z-10 flex size-14 shrink-0 items-center justify-center rounded-full bg-indigo-50 ring-1 ring-indigo-100 dark:bg-indigo-900/30 dark:ring-indigo-900/40">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-7 text-indigo-600 dark:text-indigo-400" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m-18.432 0A8.959 8.959 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
            </div>
            <p class="self-center text-sm/6 font-medium text-indigo-600 dark:text-indigo-400">{{ item.gapNote }}</p>
          </li>
        {% endif %}

        {% set partner = history[loop.index] %}
        <li class="relative flex gap-x-6 {% if loop.last %}pb-0{% else %}pb-14{% endif %}">
          {{ marker(item) }}
          <div class="min-w-0 flex-1 pt-1.5">
            {% if partner and partner.parallel %}
              <div class="grid gap-y-8 sm:grid-cols-2 sm:gap-x-8">
                <div>{{ entryContent(item) }}</div>
                <div class="sm:border-s sm:border-gray-200 sm:ps-8 dark:sm:border-gray-800">
                  <div class="mb-3">{{ marker(partner, 'size-10', 'max-w-7 max-h-7') }}</div>
                  {{ entryContent(partner) }}
                </div>
              </div>
            {% else %}
              {{ entryContent(item) }}
            {% endif %}
          </div>
        </li>

      {% endif %}
    {% endfor %}
  </ol>
</div>
