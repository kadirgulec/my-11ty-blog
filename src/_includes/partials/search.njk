<div x-data="searchComponent()"
     @open-search.window="openModal()"
     @keydown.window.escape="closeModal()"
     @keydown.window.ctrl.k.prevent="openModal()"
     @keydown.window.meta.k.prevent="openModal()"
     class="relative z-[100]"
     x-cloak>

    <!-- Modal Backdrop -->
    <div x-show="isOpen"
         x-transition:enter="ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 bg-gray-500/75 dark:bg-gray-950/80 backdrop-blur-sm transition-opacity"></div>

    <!-- Modal Content -->
    <div x-show="isOpen"
         class="fixed inset-0 z-[101] w-screen p-4 sm:p-6 md:p-20">
        
        <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-start sm:p-0">
            <div x-show="isOpen"
                 x-transition:enter="ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave="ease-in duration-200"
                 x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 @click.away="closeModal()"
                 class="mx-auto max-w-2xl transform overflow-hidden rounded-2xl bg-white dark:bg-gray-900 shadow-2xl ring-1 ring-black ring-opacity-5 transition-all w-full text-left">

                <!-- Search Input Header -->
                <div class="relative border-b border-gray-100 dark:border-gray-800">
                    <svg class="pointer-events-none absolute left-4 top-4 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                    </svg>
                    <input type="text"
                           x-ref="searchInput"
                           class="h-14 w-full border-0 bg-transparent pl-11 pr-4 text-gray-900 dark:text-white placeholder:text-gray-400 focus:ring-0 sm:text-sm outline-none"
                           placeholder="Search blog posts, projects..."
                           x-model="query"
                           @input.debounce.300ms="performSearch()">
                </div>

                <!-- Results Section -->
                <div x-show="results.length > 0" class="max-h-[60vh] overflow-y-auto custom-scrollbar">
                    <div class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50 dark:bg-gray-800/50">
                        Results (<span x-text="results.length"></span>)
                    </div>
                    <ul class="divide-y overflow-y-auto divide-gray-50 dark:divide-gray-800" id="options" role="listbox">
                        <template x-for="result in results" :key="result.url">
                            <li class="relative">
                                <a :href="result.url" class="flex flex-col px-4 py-4 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 group transition-all duration-200">
                                    <div class="flex items-center justify-between mb-1">
                                        <span class="text-sm font-bold text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors" x-text="result.meta.title"></span>
                                        <span class="text-[10px] px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 group-hover:bg-indigo-100 dark:group-hover:bg-indigo-900/50 transition-colors uppercase font-medium">Page</span>
                                    </div>
                                    <div class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 leading-relaxed search-excerpt" x-html="result.excerpt"></div>
                                    <div class="mt-2 text-[11px] text-gray-400 dark:text-gray-500 flex items-center">
                                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.823a4 4 0 015.656 0l4 4a4 4 0 01-5.656 5.656l-1.103-1.103"></path></svg>
                                        <span x-text="result.url"></span>
                                    </div>
                                </a>
                            </li>
                        </template>
                    </ul>
                </div>

                <!-- Empty state -->
                <div x-show="query.length >= 2 && results.length === 0 && !loading" class="px-6 py-14 text-center sm:px-14 bg-white dark:bg-gray-900">
                    <div class="flex justify-center mb-4">
                        <div class="bg-gray-100 dark:bg-gray-800 p-3 rounded-full">
                            <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                            </svg>
                        </div>
                    </div>
                    <p class="text-base font-semibold text-gray-900 dark:text-white">No results found</p>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">We couldn't find anything matching "<span x-text="query" class="font-medium text-gray-900 dark:text-gray-200"></span>".</p>
                </div>

                <!-- Initial/Idle state -->
                <div x-show="query.length < 2 && !loading" class="px-6 py-10 text-center bg-white dark:bg-gray-900">
                    <p class="text-sm text-gray-500 dark:text-gray-400">Type at least 2 characters to start searching...</p>
                    <div class="mt-4 flex justify-center gap-4 text-[11px] text-gray-400 uppercase tracking-widest font-medium">
                        <span class="flex items-center"><kbd class="px-1.5 py-0.5 rounded border border-gray-300 dark:border-gray-700 mr-1.5 font-sans bg-gray-50 dark:bg-gray-800 text-gray-500">ESC</kbd> to close</span>
                        <span class="flex items-center"><kbd class="px-1.5 py-0.5 rounded border border-gray-300 dark:border-gray-700 mr-1.5 font-sans bg-gray-50 dark:bg-gray-800 text-gray-500">ENTER</kbd> to select</span>
                    </div>
                </div>

                <!-- Loading state -->
                <div x-show="loading" class="px-6 py-14 text-center sm:px-14 bg-white dark:bg-gray-900">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-indigo-500 border-t-transparent mb-4"></div>
                    <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">Searching our database...</p>
                </div>

                <!-- Footer / Shortcuts -->
                <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 flex items-center justify-between text-[11px] text-gray-400">
                    <div class="flex items-center">
                        Powered by <span class="ml-1 font-bold text-gray-500 dark:text-gray-300">Pagefind</span>
                    </div>
                    <div class="hidden sm:block">
                        <span class="bg-gray-200 dark:bg-gray-700 px-1.5 py-0.5 rounded text-gray-600 dark:text-gray-300 mr-1">↑↓</span> to navigate
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function searchComponent() {
        return {
            isOpen: false,
            query: '',
            results: [],
            pagefind: null,
            loading: false,

            async initPagefind() {
                if (this.pagefind) return;
                try {
                    this.pagefind = await import("/pagefind/pagefind.js");
                    await this.pagefind.options({
                        "excerptLength": 20
                    });
                } catch (e) {
                    console.error("Pagefind failed to load", e);
                }
            },

            async openModal() {
                this.isOpen = true;
                this.query = '';
                this.results = [];
                await this.initPagefind();
                this.$nextTick(() => {
                    this.$refs.searchInput.focus();
                });
            },

            closeModal() {
                this.isOpen = false;
            },

            async performSearch() {
                if (this.query.length < 2) {
                    this.results = [];
                    return;
                }

                this.loading = true;
                await this.initPagefind();

                if (!this.pagefind) {
                    this.loading = false;
                    return;
                }

                const search = await this.pagefind.search(this.query);
                const resultsData = await Promise.all(
                    search.results.slice(0, 20).map(r => r.data())
                );

                this.results = resultsData;
                this.loading = false;
            }
        }
    }
</script>
